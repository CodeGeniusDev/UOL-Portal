generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  role         Role        @default(STUDENT)
  departmentId String?
  createdAt    DateTime    @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  documents Document[]
  users     User[]
}

model Document {
  id             String          @id @default(uuid())
  filePath       String
  type           String
  departmentId   String
  contentSummary String?
  createdAt      DateTime        @default(now())
  department     Department      @relation(fields: [departmentId], references: [id])
  chunks         KnowledgeBase[]
}

model KnowledgeBase {
  id              String                 @id @default(uuid())
  documentId      String
  textChunk       String
  vectorEmbedding Unsupported("vector")?
  createdAt       DateTime               @default(now())
  document        Document               @relation(fields: [documentId], references: [id])
}

enum Role {
  ADMIN
  STUDENT
}
